# Postgres (см. docker-compose.yml)
EASYRAG_DB_DSN=postgresql+asyncpg://easyrag:easyrag@localhost:5435/easyrag
EASYRAG_DB_DSN_SYNC=postgresql+psycopg://easyrag:easyrag@localhost:5435/easyrag

# --- LLM (LangChain) ---
# Провайдер: openai | gigachat
EASYRAG_LLM_PROVIDER=openai
EASYRAG_LLM_MODEL=gpt-4o-mini
EASYRAG_LLM_MAX_TOKENS=2048
EASYRAG_LLM_TEMPERATURE=0.0
# 1 = вернуть детерминированные мок-ответы (для тестов)
EASYRAG_LLM_MOCK=0

# OpenAI / OpenAI-совместимый endpoint (langchain_openai.ChatOpenAI)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# GigaChat (langchain_gigachat.GigaChat)
GIGACHAT_CREDENTIALS=
EASYRAG_GIGACHAT_SCOPE=GIGACHAT_API_PERS
EASYRAG_GIGACHAT_VERIFY_SSL=0

# --- Embeddings (LangChain) ---
EASYRAG_EMBED_PROVIDER=openai
EASYRAG_EMBED_MODEL=text-embedding-3-small
EASYRAG_EMBED_DIM=1536
EASYRAG_EMBED_MOCK=0

# OpenAI / OpenAI-совместимый endpoint (langchain_openai.OpenAIEmbeddings)
EMBED_API_KEY=
# EMBED_BASE_URL=https://api.openai.com/v1

# Пороги
EASYRAG_RESOLVE_THRESH_HIGH=0.85
EASYRAG_RESOLVE_THRESH_LOW=0.65
EASYRAG_ABBR_THRESH_HIGH=0.80
EASYRAG_GRAPH_EXPAND_THRESH=0.55
